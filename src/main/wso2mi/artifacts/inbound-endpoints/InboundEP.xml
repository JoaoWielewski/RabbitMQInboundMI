<?xml version="1.0" encoding="UTF-8"?>
<inboundEndpoint name="RMQInboundEP"
                 protocol="rabbitmq"
                 onError="RMQInboundErrorSequence"
                 sequence="RMQInboundSequence"
                 suspend="false"
                 xmlns="http://ws.apache.org/ns/synapse">
    <parameters>
        <parameter name="sequential">true</parameter>
        <parameter name="coordination">true</parameter>
        <parameter name="rabbitmq.connection.factory">AMQPConnectionFactorySender</parameter>
        <parameter name="rabbitmq.server.host.name">$SYSTEM:HOSTNAME</parameter>
        <parameter name="rabbitmq.server.port">5672</parameter>
        <parameter name="rabbitmq.server.user.name">$SYSTEM:USERNAME</parameter>
        <parameter name="rabbitmq.server.password">$SYSTEM:PASSWORD</parameter>
        <parameter name="rabbitmq.server.virtual.host">/</parameter>
        <parameter name="rabbitmq.queue.name">RMQChoreoPoC</parameter>
        <parameter name="rabbitmq.queue.auto.ack">true</parameter>
        <parameter name="rabbitmq.exchange.name">RMQChoreoPoC</parameter>
        <parameter name="rabbitmq.queue.routing.key">RMQChoreoPoC</parameter>
        <parameter name="rabbitmq.queue.auto.declare">true</parameter>
        <parameter name="rabbitmq.exchange.auto.declare">false</parameter>
        <parameter name="rabbitmq.queue.durable">true</parameter>
    </parameters>
</inboundEndpoint>
