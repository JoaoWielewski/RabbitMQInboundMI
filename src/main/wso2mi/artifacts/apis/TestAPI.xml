<?xml version="1.0" encoding="UTF-8"?>
<api context="/testapi" name="TestAPI" xmlns="http://ws.apache.org/ns/synapse">
    <resource methods="GET" uri-template="/">
        <inSequence>
            <log category="INFO" level="custom">
                <property name="hostname" scope="default" type="STRING" expression="${configs.hostname}"/>
                <property name="username" scope="default" type="STRING" expression="${configs.username}"/>
                <property name="password" scope="default" type="STRING" expression="${configs.password}"/>
            </log>
            <respond />
        </inSequence>
        <faultSequence>
        </faultSequence>
    </resource>
</api>